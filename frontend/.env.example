# Rezerv frontend — environment variables
# Copy to .env (gitignored) for local dev, or set in Vercel project settings.

# Show the dev-mode login JWT box outside of `vite dev`. Default: false.
# Leave false in production. Set to "true" only on a private preview where
# you need to paste a JWT to walk the app without Telegram.
VITE_DEV_BYPASS_TELEGRAM=false

# Override the API base URL. Leave UNSET in production — Vercel's rewrite
# (vercel.json) proxies /api/* to the Railway backend, so the browser only
# ever sees same-origin requests (no CORS). Useful for local dev pointing
# at the live backend without running it locally:
#   VITE_API_BASE_URL=https://resevationapp-backend-production.up.railway.app/api/v1
# VITE_API_BASE_URL=
