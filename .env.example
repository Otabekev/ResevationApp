# ── Database ──────────────────────────────────────────────
POSTGRES_USER=rezerv
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rezerv_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Local Docker: postgresql+asyncpg://rezerv:changeme@db:5432/rezerv_db
# Neon:        postgres://user:pass@ep-xxx.neon.tech/neondb  (SSL added automatically)
DATABASE_URL=postgresql+asyncpg://rezerv:changeme@db:5432/rezerv_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
# Bot username WITHOUT @ (e.g. QulayNavbat_bot) — used to build t.me invite/login links
TELEGRAM_BOT_USERNAME=YourBot_bot
TELEGRAM_WEBHOOK_SECRET=change-this-random-string
# Full URL where the bot webhook will be registered
WEBHOOK_BASE_URL=https://yourdomain.com
# Shared secret between bot and backend (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BOT_SECRET=change-this-random-string-for-bot

# ── Platform ──────────────────────────────────────────────
PLATFORM_NAME=Rezerv
# Comma-separated telegram IDs that get super_admin role on first login
SUPER_ADMIN_TELEGRAM_IDS=123456789

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
# development | production
